digraph ListaImagenes {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=lightgreen];
    { rank=same;
        img1 [label="Imagen: 1"];
        img2 [label="Imagen: 2"];
        img3 [label="Imagen: 3"];
    }
    img1 -> img2 [dir=both];
    capa1_1 [label="Capa: 1", fillcolor=lightyellow];
    img1 -> capa1_1;
    capa1_2 [label="Capa: 2", fillcolor=lightyellow];
    capa1_1 -> capa1_2;
    capa1_3 [label="Capa: 3", fillcolor=lightyellow];
    capa1_2 -> capa1_3;
    img2 -> img3 [dir=both];
    capa2_2 [label="Capa: 2", fillcolor=lightyellow];
    img2 -> capa2_2;
    capa2_1 [label="Capa: 1", fillcolor=lightyellow];
    capa2_2 -> capa2_1;
    capa2_3 [label="Capa: 3", fillcolor=lightyellow];
    capa2_1 -> capa2_3;
    img3 -> img1 [dir=both];
    capa3_1 [label="Capa: 1", fillcolor=lightyellow];
    img3 -> capa3_1;
    capa3_3 [label="Capa: 3", fillcolor=lightyellow];
    capa3_1 -> capa3_3;
    capa3_2 [label="Capa: 2", fillcolor=lightyellow];
    capa3_3 -> capa3_2;
}
